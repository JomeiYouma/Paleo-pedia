# ── Variables d'environnement PRODUCTION o2switch ─────────────────
# Copier ce fichier en .env sur le serveur et remplir les valeurs réelles.
# Ne JAMAIS committer le .env réel dans Git.

# Connexion MySQL (créée dans cPanel > MySQL Databases)
DATABASE_URL="mysql://utilisateur_cpanel:mot_de_passe@localhost:3306/nom_base"

# Clé JWT — générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OBLIGATOIRE en production : le serveur REFUSE de démarrer sans (cf. server.js).
JWT_SECRET="REMPLACER_PAR_UNE_CHAINE_ALEATOIRE_LONGUE"

# ── Compte admin initial (script seed_admin.js) ──────────────
# En production, le mot de passe est OBLIGATOIRE (8+ caractères) : le seed
# REFUSE de créer le compte « admin / admin » par défaut.
SEED_ADMIN_EMAIL=admin@atelier21.org
SEED_ADMIN_PASSWORD="REMPLACER_PAR_UN_MOT_DE_PASSE_FORT"

# ── Durcissement (valeurs par défaut sûres si absentes) ──────
# Inscription publique (POST /api/auth/register) : DÉSACTIVÉE par défaut. Ne
# passer à "true" que si un parcours d'inscription public devient nécessaire.
# ALLOW_PUBLIC_REGISTRATION=false
# Anti-force-brute sur la connexion (défauts : 15 tentatives / 15 min / IP)
# LOGIN_MAX_ATTEMPTS=15
# LOGIN_WINDOW_MS=900000

# Port attribué par o2switch dans "Setup Node.js App" (ne pas modifier manuellement)
PORT=3001

# Environnement
NODE_ENV=production

# Origine autorisée pour CORS (ton domaine exact, sans slash final)
# Exemple : ALLOWED_ORIGIN=https://paleo.ton-domaine.fr
ALLOWED_ORIGIN=https://ton-domaine.fr

# Dossier de stockage des images uploadées
# IMPORTANT : mettre un chemin HORS du dossier de l'app pour préserver les images entre déploiements.
# Créer le dossier sur o2switch : mkdir ~/paleo-uploads
# Puis migrer les images existantes : mv ~/paleo-app/public/images/* ~/paleo-uploads/
UPLOADS_DIR=/home/ton_cpanel_user/paleo-uploads

# Clé API traduction (stockée en BDD via l'interface admin, mais peut aussi être forcée ici)
# OPENAI_KEY=sk-...  ou clé DeepL :fx

# ── Notifications email (event_email_config) ─────────────────
# Configurer le SMTP pour activer l'envoi d'emails configurables depuis
# Admin > Journal d'événements > Configuration emails.
# Si ces variables sont absentes, l'app fonctionne mais aucun email ne part.
# Exemples :
#   o2switch (boîte cPanel)  : MAIL_SMTP_HOST=mail.ton-domaine.fr  MAIL_SMTP_PORT=465  MAIL_SMTP_SECURE=true
#   Gmail / Workspace        : MAIL_SMTP_HOST=smtp.gmail.com      MAIL_SMTP_PORT=587  MAIL_SMTP_SECURE=false
#                              (utiliser un "mot de passe d'application")
# MAIL_SMTP_HOST=mail.ton-domaine.fr
# MAIL_SMTP_PORT=465
# MAIL_SMTP_SECURE=true
# MAIL_SMTP_USER=hello@atelier21.org
# MAIL_SMTP_PASS=...
# MAIL_FROM="Paléo-Énergétique <hello@atelier21.org>"
